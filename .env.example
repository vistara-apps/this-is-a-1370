# API Configuration
VITE_API_BASE_URL=http://localhost:3001/api

# Pinata IPFS Configuration
VITE_PINATA_JWT=your_pinata_jwt_token_here
VITE_PINATA_API_KEY=your_pinata_api_key_here
VITE_PINATA_SECRET_KEY=your_pinata_secret_key_here

# Smart Contract Addresses (Base Network)
VITE_FILEPAY_CONTRACT_ADDRESS=0x...
VITE_USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# WalletConnect Project ID
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Stripe Configuration (Optional)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Base Network Configuration
VITE_BASE_RPC_URL=https://mainnet.base.org
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Application Configuration
VITE_APP_NAME=FilePay
VITE_APP_DESCRIPTION=Monetize your digital files with pay-per-download access
VITE_PLATFORM_FEE_PERCENTAGE=2.5

# Security Configuration
VITE_MAX_FILE_SIZE_MB=100
VITE_ALLOWED_FILE_TYPES=pdf,doc,docx,txt,zip,jpg,jpeg,png,gif,mp4,mp3,wav

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=G-...
VITE_MIXPANEL_TOKEN=...

# Development Configuration
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=debug
